<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="bp" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="pe.edu.upeu.controller.MainguiController">
    <top>
        <MenuBar fx:id="menuBar">
            <menus>
                <Menu text="Mantenimiento">
                    <items>
                        <MenuItem fx:id="menuItem1" text="Adm. Locales" />
                        <MenuItem fx:id="menuItem2" text="Búsquedas" />
                        <MenuItem fx:id="menuItem3" text="Cerrar" />
                    </items>
                </Menu>
            </menus>
        </MenuBar>
    </top>
    <center>
        <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE">
            <tabs>
                <Tab text="Bienvenido" />
            </tabs>
        </TabPane>
    </center>
</BorderPane>