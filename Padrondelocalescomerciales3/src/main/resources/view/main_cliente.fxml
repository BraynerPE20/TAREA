<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="pe.edu.upeu.controller.MainClienteController">
    <children>
        <VBox AnchorPane.bottomAnchor="5.0" AnchorPane.leftAnchor="5.0" AnchorPane.rightAnchor="5.0" AnchorPane.topAnchor="5.0">
            <children>
                <!-- HEADER CON BUSCADOR -->
                <AnchorPane style="-fx-background-color:#2c3e50; -fx-padding:10;">
                    <children>
                        <Label layoutX="14.0" layoutY="14.0" style="-fx-text-fill:white; -fx-font-size:18px; -fx-font-weight:bold;" text="PADRÓN DE LOCALES COMERCIALES" />
                        <TextField fx:id="txtBuscar" layoutX="400.0" layoutY="12.0" prefWidth="200.0" promptText="Buscar local..." style="-fx-background-radius:15;" AnchorPane.rightAnchor="10.0" />
                        <Label layoutX="340.0" layoutY="17.0" style="-fx-text-fill:white;" text="Buscar:" AnchorPane.rightAnchor="220.0" />
                    </children>
                </AnchorPane>

                <HBox spacing="10" style="-fx-padding:10;" VBox.vgrow="ALWAYS">
                    <children>
                        <!-- FORMULARIO -->
                        <GridPane hgap="10" style="-fx-background-color:white; -fx-padding:15; -fx-background-radius:10; -fx-effect:dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 5);" vgap="10">
                            <columnConstraints>
                                <ColumnConstraints prefWidth="100" />
                                <ColumnConstraints prefWidth="200" />
                            </columnConstraints>
                            <children>
                                <Label text="RUC (ID):" GridPane.rowIndex="0" />
                                <TextField fx:id="txtDni" promptText="Ingrese RUC" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                <Label text="Comercio:" GridPane.rowIndex="1" />
                                <TextField fx:id="txtNombre" promptText="Nombre del local" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                <Label text="Título:" GridPane.rowIndex="2" />
                                <TextField fx:id="txtTelefono" promptText="Giro del negocio" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                <Label text="Representante:" GridPane.rowIndex="3" />
                                <TextField fx:id="txtEmail" promptText="Propietario" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                                <HBox alignment="CENTER" spacing="10" GridPane.columnSpan="2" GridPane.rowIndex="5">
                                    <Button fx:id="btnGuardar" maxWidth="100" style="-fx-background-color: #28a745; -fx-text-fill: white;" text="Guardar" />
                                    <Button fx:id="btnActualizar" maxWidth="100" style="-fx-background-color: #ffc107;" text="Actualizar" />
                                </HBox>
                                <HBox alignment="CENTER" spacing="10" GridPane.columnSpan="2" GridPane.rowIndex="6">
                                    <Button fx:id="btnLimpiar" maxWidth="100" style="-fx-background-color: #6c757d; -fx-text-fill: white;" text="Limpiar" />
                                    <Button fx:id="btnEliminar" maxWidth="100" onAction="#eliminar" style="-fx-background-color: #dc3545; -fx-text-fill: white;" text="Eliminar" />
                                </HBox>
                            </children>
                            <rowConstraints>
                                <RowConstraints />
                                <RowConstraints />
                                <RowConstraints />
                                <RowConstraints />
                                <RowConstraints />
                                <RowConstraints />
                                <RowConstraints />
                            </rowConstraints>
                        </GridPane>

                        <!-- TABLA -->
                        <TableView fx:id="tableRegCliente" HBox.hgrow="ALWAYS" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>