<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="pe.edu.upeu.controller.MainClienteController">
    <children>
        <VBox AnchorPane.bottomAnchor="5.0" AnchorPane.leftAnchor="5.0" AnchorPane.rightAnchor="5.0" AnchorPane.topAnchor="5.0">
            <children>
                <AnchorPane style="-fx-background-color:#2c3e50; -fx-padding:10;">
                    <children>
                        <Label style="-fx-text-fill:white; -fx-font-size:18px; -fx-font-weight:bold;" text="PADRÓN DE LOCALES COMERCIALES" />
                    </children>
                </AnchorPane>
                <HBox spacing="10" VBox.vgrow="ALWAYS" style="-fx-padding:10;">
                    <children>
                        <GridPane hgap="10" vgap="10" style="-fx-background-color:white; -fx-padding:15; -fx-background-radius:10; -fx-effect:dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                            <columnConstraints>
                                <ColumnConstraints prefWidth="100"/>
                                <ColumnConstraints prefWidth="200"/>
                            </columnConstraints>
                            <children>
                                <Label text="RUC:" GridPane.rowIndex="0" />
                                <TextField fx:id="txtRuc" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                <Label text="Comercio:" GridPane.rowIndex="1" />
                                <TextField fx:id="txtNombre" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                <Label text="Título:" GridPane.rowIndex="2" />
                                <TextField fx:id="txtTitulo" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                <Label text="Propietario:" GridPane.rowIndex="3" />
                                <TextField fx:id="txtPropietario" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                                <Label text="Dirección:" GridPane.rowIndex="4" />
                                <TextField fx:id="txtDireccion" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                                <HBox spacing="10" GridPane.columnSpan="2" GridPane.rowIndex="5" alignment="CENTER">
                                    <Button fx:id="btnGuardar" text="Guardar" styleClass="btn, btn-success" />
                                    <Button fx:id="btnActualizar" text="Actualizar" styleClass="btn, btn-warning" />
                                </HBox>
                                <HBox spacing="10" GridPane.columnSpan="2" GridPane.rowIndex="6" alignment="CENTER">
                                    <Button fx:id="btnLimpiar" text="Limpiar" styleClass="btn, btn-default" />
                                    <Button fx:id="btnEliminar" onAction="#eliminar" text="Eliminar" styleClass="btn, btn-danger" />
                                </HBox>
                            </children>
                        </GridPane>
                        <TableView fx:id="tableRegCliente" HBox.hgrow="ALWAYS" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>