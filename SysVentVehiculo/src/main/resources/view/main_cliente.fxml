<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="pe.edu.upeu.controller.MainClienteController">

    <children>
        <VBox AnchorPane.bottomAnchor="5.0" AnchorPane.leftAnchor="5.0" AnchorPane.rightAnchor="5.0" AnchorPane.topAnchor="5.0">

            <children>

                <!-- HEADER -->
                <AnchorPane style="-fx-background-color:#2c3e50;">
                    <children>
                        <Pane AnchorPane.bottomAnchor="5.0" AnchorPane.leftAnchor="5.0" AnchorPane.rightAnchor="5.0" AnchorPane.topAnchor="5.0">

                            <children>
                                <Label layoutX="24.0" layoutY="14.0" style="-fx-text-fill:white; -fx-font-size:16px; -fx-font-weight:bold;" text="Gestión de Clientes" />

                                <Label layoutX="449.0" layoutY="14.0" style="-fx-text-fill:white;" text="Buscar Cliente" />

                                <TextField fx:id="txtBuscar" layoutX="412.0" layoutY="30.0" style="-fx-background-radius:6;" />
                            </children>

                        </Pane>
                    </children>
                </AnchorPane>

                <!-- CONTENIDO -->
                <AnchorPane>
                    <children>
                        <HBox AnchorPane.bottomAnchor="5.0" AnchorPane.leftAnchor="5.0" AnchorPane.rightAnchor="5.0" AnchorPane.topAnchor="5.0">

                            <children>

                                <!-- FORMULARIO -->
                                <GridPane style="-fx-background-color:white; -fx-padding:15; -fx-background-radius:10; -fx-effect:dropshadow(gaussian, rgba(0,0,0,0.2),10,0,0,3);">

                                    <columnConstraints>
                                        <ColumnConstraints hgrow="SOMETIMES" prefWidth="100.0" />
                                        <ColumnConstraints hgrow="SOMETIMES" prefWidth="100.0" />
                                        <ColumnConstraints hgrow="SOMETIMES" prefWidth="100.0" />
                                        <ColumnConstraints hgrow="SOMETIMES" prefWidth="100.0" />
                                    </columnConstraints>

                                    <rowConstraints>
                                        <RowConstraints prefHeight="30.0" />
                                        <RowConstraints prefHeight="30.0" />
                                        <RowConstraints prefHeight="30.0" />
                                        <RowConstraints prefHeight="30.0" />
                                        <RowConstraints prefHeight="30.0" />
                                        <RowConstraints prefHeight="30.0" />
                                    </rowConstraints>

                                    <children>

                                        <Label alignment="CENTER" style="-fx-font-weight:bold; -fx-font-size:14px;" text="DATOS DEL CLIENTE" GridPane.columnSpan="4" />

                                        <Label text="DNI:" GridPane.rowIndex="1" />
                                        <Label text="Nombres:" GridPane.rowIndex="2" />
                                        <Label text="Telefono:" GridPane.rowIndex="3" />
                                        <Label text="Correo:" GridPane.rowIndex="4" />

                                        <TextField fx:id="txtDni" style="-fx-background-radius:6;" GridPane.columnIndex="1" GridPane.columnSpan="2" GridPane.rowIndex="1" />
                                        <TextField fx:id="txtNombre" style="-fx-background-radius:6;" GridPane.columnIndex="1" GridPane.columnSpan="3" GridPane.rowIndex="2" />
                                        <TextField fx:id="txtTelefono" style="-fx-background-radius:6;" GridPane.columnIndex="1" GridPane.columnSpan="2" GridPane.rowIndex="3" />
                                        <TextField fx:id="txtEmail" style="-fx-background-radius:6;" GridPane.columnIndex="1" GridPane.columnSpan="3" GridPane.rowIndex="4" />

                                        <!-- BUSCAR -->
                                        <Button style="-fx-background-color:#007bff; -fx-text-fill:white; -fx-background-radius:6;" text="Buscar" GridPane.columnIndex="3" GridPane.rowIndex="1">
                                            <GridPane.margin>
                                                <Insets left="5.0" />
                                            </GridPane.margin>
                                        </Button>

                                        <!-- GUARDAR -->
                                        <Button fx:id="btnGuardar" maxWidth="1.7976931348623157E308" style="-fx-background-color:#28a745; -fx-text-fill:white; -fx-background-radius:6;" text="Guardar" GridPane.rowIndex="5">
                                            <GridPane.margin>
                                                <Insets right="5.0" />
                                            </GridPane.margin>
                                        </Button>

                                        <!-- ACTUALIZAR -->
                                        <Button fx:id="btnActualizar" maxWidth="1.7976931348623157E308" style="-fx-background-color:#ffc107; -fx-text-fill:black; -fx-background-radius:6;" text="Actualizar" GridPane.columnIndex="1" GridPane.rowIndex="5">
                                            <GridPane.margin>
                                                <Insets left="5.0" right="5.0" />
                                            </GridPane.margin>
                                        </Button>

                                        <!-- LIMPIAR -->
                                        <Button fx:id="btnLimpiar" maxWidth="1.7976931348623157E308" style="-fx-background-color:#6c757d; -fx-text-fill:white; -fx-background-radius:6;" text="Limpiar" GridPane.columnIndex="2" GridPane.rowIndex="5">
                                            <GridPane.margin>
                                                <Insets left="5.0" right="5.0" />
                                            </GridPane.margin>
                                        </Button>

                                        <!-- ELIMINAR -->
                                        <Button fx:id="btnEliminar" maxWidth="1.7976931348623157E308" onAction="#eliminar" style="-fx-background-color:#dc3545; -fx-text-fill:white; -fx-background-radius:6; -fx-font-size:14px;" text="Eliminar" GridPane.columnIndex="3" GridPane.rowIndex="5">
                                            <GridPane.margin>
                                                <Insets left="5.0" right="5.0" />
                                            </GridPane.margin>
                                        </Button>

                                    </children>
                                </GridPane>

                                <!-- TABLA -->
                                <TableView fx:id="tableRegCliente" style="-fx-background-color:white; -fx-border-color:#ddd;">
                                    <HBox.margin>
                                        <Insets left="5.0" />
                                    </HBox.margin>
                                </TableView>

                            </children>
                        </HBox>
                    </children>
                </AnchorPane>

            </children>
        </VBox>
    </children>
</AnchorPane>
